# The submit-news intake page ships TWO language variants (NL + EN)
# selected at first paint by ?lang=. To prevent stale CDN/browser
# copies from masking content fixes (e.g. the 2026-04-27 EN-form
# `hidden` regression), force revalidation on every load. Both URL
# forms map to the same asset on Cloudflare Pages — list both so
# the rule applies whether visitors hit the canonical .html path or
# the extensionless variant Wouter shares in outreach.
/submit-news.html
  Cache-Control: public, max-age=0, must-revalidate
/submit-news
  Cache-Control: public, max-age=0, must-revalidate
